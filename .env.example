# Server
PORT=3001
HOST=0.0.0.0

# APRS-IS connection
APRS_HOST=aprs.glidernet.org
APRS_PORT=14580
APRS_FILTER_LAT=51.5674
APRS_FILTER_LON=4.9318
APRS_FILTER_RANGE_KM=500

# Database
DB_PATH=./data/ogn-dashboard.db

# Receiver API keys (comma-separated receiver_id:key pairs)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RECEIVER_API_KEYS=EHGR:change-me-to-a-real-key
